<html>
<head>
    <meta charset="UTF-8">
    <title>Đăng ký tham gia Hội thao</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            display: flex;
            justify-content: center;
            padding-top: 50px;
        }
        .form-container {
            border: 1px solid #4a7ebb;
            padding: 20px;
            width: 450px;
            line-height: 1.8;
        }
        h2 {
            margin-top: 0;
            font-size: 22px;
        }
        .input-group {
            margin-bottom: 10px;
        }
        input[type="text"], input[type="email"] {
            width: 300px;
            padding: 2px;
            border: 1px solid #767676;
        }
        label {
            display: inline-block;
            width: 100px;
        }
        .radio-group, .checkbox-group {
            margin-top: 10px;
        }
        .checkbox-item {
            display: block;
            margin-left: 5px;
        }
        .button-group {
            margin-top: 15px;
        }
        button {
            padding: 2px 10px;
            cursor: pointer;
        }
    </style>
</head>
<body>

<div class="form-container">
    <h2>Đăng kí tham gia Hội thao</h2>

    <div class="input-group">
        <label for="fullname">Họ và tên:</label>
        <input type="text" id="fullname" name="fullname">
    </div>

    <div class="input-group">
        <label for="email">Địa chỉ email:</label>
        <input type="email" id="email" name="email">
    </div>

    <div class="radio-group">
        <input type="radio" id="l10" name="grade" value="10">
        <label for="l10" style="width: auto; margin-right: 15px;">Lớp 10</label>

        <input type="radio" id="l11" name="grade" value="11">
        <label for="l11" style="width: auto; margin-right: 15px;">Lớp 11</label>

        <input type="radio" id="l12" name="grade" value="12">
        <label for="l12" style="width: auto;">Lớp 12</label>
    </div>

    <div class="checkbox-group">
        <p style="margin-bottom: 5px;">Tham dự môn:</p>
        <div class="checkbox-item">
            <input type="checkbox" id="pingpong">
            <label for="pingpong" style="width: auto;">Bóng bàn</label>
        </div>
        <div class="checkbox-item">
            <input type="checkbox" id="badminton">
            <label for="badminton" style="width: auto;">Cầu lông</label>
        </div>
        <div class="checkbox-item">
            <input type="checkbox" id="chess">
            <label for="chess" style="width: auto;">Cờ vua</label>
        </div>
    </div>

    <div class="button-group">
        <button type="submit">Đăng kí</button>
        <button type="reset">Huỷ bỏ</button>
    </div>
</div>

</body>
</html>
