<html>
<head>
    <meta charset="UTF-8">
    <title>Đóng góp ý kiến</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            margin: 40px;
            background-color: #f9f9f9;
        }
        .container {
            width: 450px; /* Tăng nhẹ chiều rộng để không bị chật */
            border: 1px solid #ccc;
            padding: 20px;
            background: white;
            box-shadow: 2px 2px 10px rgba(0,0,0,0.1);
        }
        h2 {
            text-align: center;
            color: #333;
        }
        /* Style cho các ô nhập liệu văn bản */
        input[type="text"], 
        input[type="email"], 
        textarea {
            width: 100%;
            margin: 5px 0 15px 0;
            padding: 8px;
            border: 1px solid #ccc;
            border-radius: 4px;
            box-sizing: border-box;
        }
        textarea {
            height: 100px;
        }

        /* Style riêng cho phần Checkbox */
        .checkbox-group {
            margin-bottom: 15px;
            padding: 10px;
            background: #fff;
        }
        .checkbox-item {
            display: flex;
            align-items: center;
            margin-bottom: 8px;
            cursor: pointer;
        }
        .checkbox-item input {
            width: auto; /* Tránh bị kéo giãn 100% theo style chung */
            margin: 0 10px 0 0;
        }
        
        button {
            padding: 10px 20px;
            background-color: #f0f0f0;
            border: 1px solid #999;
            cursor: pointer;
            font-weight: bold;
        }
        button:hover {
            background-color: #e0e0e0;
        }
    </style>
</head>
<body>

<div class="container">
    <h2>Đóng góp ý kiến cho thư viện của nhà trường</h2>

    <form>
        <h3>1. Thông tin về người góp ý</h3>
        <label>Họ và tên:</label>
        <input type="text" name="hoten">

        <label>Địa chỉ email:</label>
        <input type="email" name="email">

        <h3>2. Đóng góp ý kiến</h3>
        
        <label><strong>Thể loại cần bổ sung thêm sách:</strong></label>
        <div class="checkbox-group">
            <label class="checkbox-item"><input type="checkbox" name="theloai" value="truyen-ngan"> Truyện ngắn</label>
            <label class="checkbox-item"><input type="checkbox" name="theloai" value="ky-nang-song"> Kỹ năng sống</label>
            <label class="checkbox-item"><input type="checkbox" name="theloai" value="cntt"> Công nghệ thông tin</label>
            <label class="checkbox-item"><input type="checkbox" name="theloai" value="truyen-tranh"> Truyện tranh</label>
            <label class="checkbox-item"><input type="checkbox" name="theloai" value="lich-su"> Lịch sử</label>
        </div>

        <label>Ý kiến đóng góp khác:</label>
        <textarea name="ykien"></textarea>

        <button type="submit">Góp ý</button>
    </form>
</div>

</body>
</html>
